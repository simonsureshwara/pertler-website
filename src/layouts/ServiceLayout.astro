---
import BaseLayout from "./BaseLayout.astro";
import EmergencyBanner from "../components/EmergencyBanner.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  serviceSchema?: Record<string, any>;
  activeCompany?: "pertler" | "service" | "elektro" | "bad";
}

const { title, description, serviceSchema, activeCompany } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <EmergencyBanner />
  <Navbar />
  <main>
    <slot />
  </main>
  <Footer activeCompany={activeCompany} />
  {serviceSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  )}
</BaseLayout>
