---
import CookieBanner from "../components/CookieBanner.astro";

interface Props {
  title: string;
  description?: string;
  preloadImage?: string;
}

const { title, description = "Heizung, Sanitär, Elektrotechnik, Bäder und Kältetechnik in München — seit 1984. Meisterbetrieb Ernst Pertler GmbH.", preloadImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="de" class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:locale" content="de_DE" />
  <meta property="og:site_name" content="PERTLER Gebäudetechnik" />
  <meta property="og:image" content="https://www.pertler.de/images/og-image.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter Cards -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://www.pertler.de/images/og-image.jpg" />

  <!-- Language -->
  <link rel="alternate" hreflang="de-DE" href={canonicalURL} />
  <link rel="alternate" hreflang="x-default" href={canonicalURL} />

  <!-- Preloads -->
  {preloadImage && <link rel="preload" as="image" href={preloadImage} />}
  <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin-wght-normal.woff2" crossorigin />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- JSON-LD: LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Ernst Pertler GmbH",
    "description": "Meisterbetrieb für Heizung, Sanitär, Elektrotechnik, Bäder und Kältetechnik in München.",
    "url": "https://www.pertler.de",
    "telephone": "+49-89-35894978",
    "email": "info@pertler.de",
    "foundingDate": "1984",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Wilhelmine-Reichard-Str. 24",
      "addressLocality": "München",
      "postalCode": "80935",
      "addressCountry": "DE"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 48.1951,
      "longitude": 11.5574
    },
    "areaServed": "München und Umgebung",
    "priceRange": "$$",
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "07:30",
      "closes": "17:00"
    }
  })} />

  <style is:global>
    @import "../styles/global.css";
  </style>
</head>
<body>
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-0 focus:left-0 focus:z-[9999] focus:px-6 focus:py-3 focus:bg-primary focus:text-white focus:font-bold">
    Zum Hauptinhalt springen
  </a>
  <slot />
  <CookieBanner />
</body>
</html>
