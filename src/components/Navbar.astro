---
import { Phone, Menu, X } from "lucide-astro";

const navLinks = [
  { label: "Leistungen", href: "/leistungen/" },
  { label: "Rechner", href: "/rechner/" },
  { label: "Über uns", href: "/ueber-uns/" },
  { label: "Karriere", href: "/karriere/" },
  { label: "Kontakt", href: "/kontakt/" },
];
---

<nav class="fixed top-0 z-50 w-full glass-nav bg-surface/70 shadow-sm transition-all duration-300" id="main-nav">
  <div class="max-w-screen-2xl mx-auto flex justify-between items-center px-8 py-4">
    <div class="flex items-center gap-8">
      <a href="/" class="text-2xl font-black text-gray-500 border-b-2 border-primary-container tracking-tight font-headline uppercase">
        PERTLER
      </a>
      <div class="hidden lg:flex gap-8 items-center">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-on-surface-variant font-medium hover:text-primary transition-colors duration-300 font-headline tracking-tight uppercase text-sm"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
    <div class="flex items-center gap-4">
      <a
        href="tel:08935894978"
        class="hidden lg:flex items-center gap-2 text-primary font-bold hover:opacity-80 transition-opacity"
      >
        <Phone class="w-4 h-4" />
        <span>089 / 35 89 49 78</span>
      </a>
      <a
        href="/buchung/"
        class="hidden sm:inline-flex cta-gradient text-white py-3 px-6 rounded-md font-bold transition-all active:scale-95 text-sm uppercase tracking-wider hover:opacity-90"
      >
        Angebot anfordern
      </a>
      <!-- Mobile menu button -->
      <button
        id="mobile-menu-toggle"
        class="lg:hidden p-2 text-on-surface"
        aria-label="Menü öffnen"
      >
        <Menu class="w-6 h-6" id="menu-open-icon" />
        <X class="w-6 h-6 hidden" id="menu-close-icon" />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-surface-container-lowest border-t border-outline-variant/15 px-8 pb-6">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="block py-3 text-on-surface font-headline font-bold uppercase tracking-tight border-b border-outline-variant/10"
      >
        {link.label}
      </a>
    ))}
    <div class="mt-4 flex flex-col gap-3">
      <a href="tel:08935894978" class="flex items-center gap-2 text-primary font-bold py-3">
        <Phone class="w-5 h-5" />
        089 / 35 89 49 78
      </a>
      <a href="/buchung/" class="cta-gradient text-white py-3 px-6 rounded-md font-bold text-center text-sm uppercase">
        Angebot anfordern
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });
</script>
