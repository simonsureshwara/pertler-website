---
import { Star, ChevronLeft, ChevronRight } from "lucide-astro";

interface Props {
  filter?: string;
}

const { filter } = Astro.props;

const reviews = [
  {
    name: "Familie Schneider",
    location: "München-Bogenhausen",
    text: "Hervorragende Arbeit bei unserer Heizungssanierung. Von der Beratung bis zur Umsetzung alles professionell und termingerecht. Klare Empfehlung!",
    rating: 5,
    service: "Heizungssanierung",
    category: "heizung",
    timeAgo: "vor 3 Monaten",
  },
  {
    name: "Hausverwaltung Brandl",
    location: "München-Schwabing",
    text: "Seit über 10 Jahren unser verlässlicher Partner für alle Haustechnik-Themen. Der Notdienst war mehrfach innerhalb einer Stunde vor Ort.",
    rating: 5,
    service: "Kundendienst",
    category: "kundendienst",
    timeAgo: "vor 6 Monaten",
  },
  {
    name: "Dr. Martin Weber",
    location: "München-Feldmoching",
    text: "Unser neues Badezimmer ist ein Traum. Das Pertler-Team hat unsere Vorstellungen perfekt umgesetzt und war dabei stets sauber und pünktlich.",
    rating: 5,
    service: "Badsanierung",
    category: "baeder",
    timeAgo: "vor 2 Monaten",
  },
  {
    name: "Architekturbüro Riedl",
    location: "München-Grünwald",
    text: "Die KNX-Installation in unserer Villa wurde perfekt umgesetzt. Kompetente Beratung, saubere Verkabelung und die Programmierung lief einwandfrei.",
    rating: 5,
    service: "Elektroinstallation",
    category: "elektro",
    timeAgo: "vor 4 Monaten",
  },
  {
    name: "Thomas M.",
    location: "München-Sendling",
    text: "Wärmepumpe installiert und Fußbodenheizung im gesamten EG. Alles aus einer Hand, termingerecht und sehr sauber gearbeitet. Top Betrieb!",
    rating: 5,
    service: "Wärmepumpe",
    category: "heizung",
    timeAgo: "vor 5 Monaten",
  },
  {
    name: "Immobilienverwaltung Koch",
    location: "München-Maxvorstadt",
    text: "Betreuen mehrere unserer Objekte. Schnelle Reaktionszeiten, faire Preise und die Techniker sind immer freundlich und kompetent.",
    rating: 5,
    service: "Wartung & Service",
    category: "kundendienst",
    timeAgo: "vor 1 Monat",
  },
];

const filtered = filter ? reviews.filter(r => r.category === filter) : reviews;
---

<section class="py-24 bg-surface-container-low">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-8">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-12 gap-4">
      <div>
        <span class="text-secondary font-bold tracking-widest uppercase text-sm mb-4 block">Kundenstimmen</span>
        <h2 class="text-2xl sm:text-4xl md:text-5xl font-black tracking-tighter">Was unsere Kunden sagen.</h2>
      </div>
      <!-- Google Badge -->
      <div class="flex items-center gap-3 bg-surface-container-lowest px-5 py-3 rounded-full editorial-shadow">
        <svg viewBox="0 0 24 24" width="24" height="24" class="shrink-0">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        <div>
          <div class="flex items-center gap-1">
            {Array.from({ length: 5 }).map(() => (
              <Star class="w-3.5 h-3.5 text-[#FBBC05] fill-[#FBBC05]" />
            ))}
          </div>
          <div class="text-xs text-on-surface-variant font-medium">Google Bewertungen</div>
        </div>
      </div>
    </div>

    <!-- Slider Container -->
    <div class="relative">
      <div class="overflow-hidden" id="testimonial-slider">
        <div class="flex transition-transform duration-500 ease-out" id="testimonial-track" style={`width: ${filtered.length * 100}%;`}>
          {filtered.map((review) => (
            <div class="px-2 sm:px-4" style={`width: ${100 / filtered.length}%;`}>
              <div class="bg-surface-container-lowest p-8 sm:p-10 rounded-xl editorial-shadow h-full flex flex-col">
                <!-- Google icon + stars -->
                <div class="flex items-center justify-between mb-6">
                  <div class="flex gap-0.5">
                    {Array.from({ length: review.rating }).map(() => (
                      <Star class="w-4 h-4 text-[#FBBC05] fill-[#FBBC05]" />
                    ))}
                  </div>
                  <svg viewBox="0 0 24 24" width="20" height="20" class="opacity-40">
                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                  </svg>
                </div>
                <p class="text-on-surface-variant leading-relaxed mb-8 flex-1">"{review.text}"</p>
                <div class="border-t border-outline-variant/15 pt-5">
                  <div class="font-bold text-on-surface">{review.name}</div>
                  <div class="text-xs text-on-surface-variant mt-0.5">{review.location} · {review.service}</div>
                  <div class="text-xs text-on-surface-variant/60 mt-1">{review.timeAgo}</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Navigation Arrows (desktop only) -->
      <button id="testimonial-prev" class="hidden md:flex absolute -left-5 top-1/2 -translate-y-1/2 w-10 h-10 bg-surface-container-lowest rounded-full editorial-shadow items-center justify-center text-on-surface-variant hover:text-primary transition-colors z-10">
        <ChevronLeft class="w-5 h-5" />
      </button>
      <button id="testimonial-next" class="hidden md:flex absolute -right-5 top-1/2 -translate-y-1/2 w-10 h-10 bg-surface-container-lowest rounded-full editorial-shadow items-center justify-center text-on-surface-variant hover:text-primary transition-colors z-10">
        <ChevronRight class="w-5 h-5" />
      </button>
    </div>

    <!-- Dots -->
    <div class="flex justify-center gap-2 mt-8" id="testimonial-dots"></div>
  </div>
</section>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  var track = document.getElementById('testimonial-track');
  var prevBtn = document.getElementById('testimonial-prev');
  var nextBtn = document.getElementById('testimonial-next');
  var dotsContainer = document.getElementById('testimonial-dots');
  if (!track) return;

  var items = track.children;
  var total = items.length;
  var current = 0;
  var perView = window.innerWidth >= 768 ? 3 : 1;

  function getPerView() {
    return window.innerWidth >= 1024 ? 3 : window.innerWidth >= 640 ? 2 : 1;
  }

  function maxSlide() {
    return Math.max(0, total - getPerView());
  }

  function update() {
    perView = getPerView();
    var slideWidth = 100 / total;
    var offset = current * slideWidth;
    track.style.transform = 'translateX(-' + offset + '%)';

    // Update dots
    if (dotsContainer) {
      dotsContainer.innerHTML = '';
      var max = maxSlide();
      for (var i = 0; i <= max; i++) {
        var dot = document.createElement('button');
        dot.className = 'w-2 h-2 rounded-full transition-all ' + (i === current ? 'bg-primary w-6' : 'bg-outline-variant/40');
        dot.setAttribute('aria-label', 'Slide ' + (i + 1));
        dot.dataset.index = i;
        dot.addEventListener('click', function() {
          current = parseInt(this.dataset.index);
          update();
        });
        dotsContainer.appendChild(dot);
      }
    }
  }

  if (prevBtn) prevBtn.addEventListener('click', function() {
    current = Math.max(0, current - 1);
    update();
  });

  if (nextBtn) nextBtn.addEventListener('click', function() {
    current = Math.min(maxSlide(), current + 1);
    update();
  });

  window.addEventListener('resize', function() { current = 0; update(); });
  update();

  // Touch swipe
  var startX = 0;
  var slider = document.getElementById('testimonial-slider');
  if (slider) {
    slider.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
    slider.addEventListener('touchend', function(e) {
      var diff = startX - e.changedTouches[0].clientX;
      if (diff > 50) { current = Math.min(maxSlide(), current + 1); update(); }
      if (diff < -50) { current = Math.max(0, current - 1); update(); }
    });
  }
});
</script>
