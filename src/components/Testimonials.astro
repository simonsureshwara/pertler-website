---
import { Star } from "lucide-astro";

const reviews = [
  {
    name: "Familie Schneider",
    location: "München-Bogenhausen",
    text: "Hervorragende Arbeit bei unserer Heizungssanierung. Von der Beratung bis zur Umsetzung alles professionell und termingerecht. Klare Empfehlung!",
    rating: 5,
    service: "Heizungssanierung",
  },
  {
    name: "Hausverwaltung Brandl",
    location: "München-Schwabing",
    text: "Seit über 10 Jahren unser verlässlicher Partner für alle Haustechnik-Themen. Der Notdienst war mehrfach innerhalb einer Stunde vor Ort.",
    rating: 5,
    service: "Kundendienst",
  },
  {
    name: "Dr. Martin Weber",
    location: "München-Feldmoching",
    text: "Unser neues Badezimmer ist ein Traum. Das Pertler-Team hat unsere Vorstellungen perfekt umgesetzt und war dabei stets sauber und pünktlich.",
    rating: 5,
    service: "Badsanierung",
  },
];
---

<section class="py-24 bg-surface-container-low">
  <div class="max-w-screen-2xl mx-auto px-8">
    <div class="text-center mb-16">
      <span class="text-secondary font-bold tracking-widest uppercase text-sm mb-4 block">Kundenstimmen</span>
      <h2 class="text-4xl md:text-5xl font-black tracking-tighter">Was unsere Kunden sagen.</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {reviews.map((review) => (
        <div class="bg-surface-container-lowest p-10 rounded-xl editorial-shadow">
          <div class="flex gap-1 mb-6">
            {Array.from({ length: review.rating }).map(() => (
              <Star class="w-5 h-5 text-secondary fill-secondary" />
            ))}
          </div>
          <p class="text-on-surface-variant leading-relaxed mb-8 italic">"{review.text}"</p>
          <div class="border-t border-outline-variant/15 pt-6">
            <div class="font-bold text-on-surface">{review.name}</div>
            <div class="text-sm text-on-surface-variant">{review.location} · {review.service}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
