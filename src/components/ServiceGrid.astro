---
import { ArrowRight, ChevronRight, Wrench, Headset } from "lucide-astro";
---

<section id="leistungen" class="py-24 md:py-32 bg-surface">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-8">
    <div class="mb-16">
      <h2 class="text-2xl sm:text-4xl md:text-5xl font-black tracking-tighter mb-4">Umfassende Kompetenz unter einem Dach.</h2>
      <div class="w-24 h-1 bg-secondary"></div>
    </div>

    <div class="grid grid-cols-12 gap-4 sm:gap-8">
      <!-- Heizung & Sanitär (large) -->
      <div class="col-span-12 lg:col-span-8 group relative overflow-hidden rounded-lg bg-surface-container-lowest editorial-shadow border-t-8 border-primary">
        <div class="p-10 flex flex-col md:flex-row gap-8">
          <div class="flex-1">
            <h3 class="text-3xl font-bold mb-4">Heizung &amp; Sanitär</h3>
            <div class="flex flex-wrap gap-2 mb-6">
              <span class="px-3 py-1 bg-surface-container text-xs font-semibold rounded-full uppercase">Wärmepumpe</span>
              <span class="px-3 py-1 bg-surface-container text-xs font-semibold rounded-full uppercase">Gasheizung</span>
              <span class="px-3 py-1 bg-surface-container text-xs font-semibold rounded-full uppercase">Wartung</span>
            </div>
            <p class="text-on-surface-variant leading-relaxed mb-8">Wir begleiten Sie von der ersten Planung bis zur regelmäßigen Wartung. Nachhaltige Wärme für Ihr Zuhause oder Gewerbeobjekt.</p>
            <a href="/leistungen/heizung-sanitaer/" class="text-primary font-bold flex items-center gap-2 hover:gap-4 transition-all">
              Mehr erfahren <ArrowRight class="w-4 h-4" />
            </a>
          </div>
          <div class="w-full md:w-1/3 h-48 md:h-auto rounded-lg overflow-hidden">
            <img
              src="/images/service-heizung.webp"
              alt="Moderne Heizungsanlage"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              width="400" height="300"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>

      <!-- Elektrotechnik -->
      <div class="col-span-12 md:col-span-6 lg:col-span-4 group bg-surface-container-lowest editorial-shadow border-t-8 border-elektro rounded-lg p-10 flex flex-col justify-between">
        <div>
          <h3 class="text-2xl font-bold mb-4">Elektrotechnik</h3>
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="px-3 py-1 bg-surface-container text-xs font-semibold rounded-full uppercase">Smart Home</span>
            <span class="px-3 py-1 bg-surface-container text-xs font-semibold rounded-full uppercase">Installation</span>
          </div>
          <p class="text-on-surface-variant text-sm leading-relaxed">Sicher, intelligent und zukunftsorientiert. Komplette Elektroinstallationen für München.</p>
        </div>
        <a href="/leistungen/elektrotechnik/" class="mt-8 text-primary font-bold flex items-center gap-2">
          Details <ChevronRight class="w-4 h-4" />
        </a>
      </div>

      <!-- Bäder & Wellness (wide with image) -->
      <div class="col-span-12 lg:col-span-7 group relative overflow-hidden rounded-lg bg-surface-container-lowest editorial-shadow border-t-8 border-secondary min-h-[280px] md:min-h-[400px] flex items-end">
        <img
          src="/images/service-baeder.webp"
          alt="Luxuriöses modernes Badezimmer"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          width="800" height="400"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
        <div class="relative p-10 text-white w-full flex justify-between items-end">
          <div class="max-w-md">
            <h3 class="text-3xl font-bold mb-2">Bäder &amp; Wellness</h3>
            <p class="text-white/80 text-sm mb-6">Vom funktionalen Duschbad bis zur privaten Spa-Landschaft.</p>
            <a href="/leistungen/baeder-wellness/" class="inline-flex items-center px-6 py-3 bg-secondary hover:bg-secondary-container text-white rounded-md font-bold transition-all">
              Projekt starten
            </a>
          </div>
        </div>
      </div>

      <!-- Kundendienst & Wartung -->
      <div class="col-span-12 md:col-span-6 lg:col-span-5 group bg-surface-container-lowest editorial-shadow border-t-8 border-sanitaer rounded-lg p-10 flex flex-col justify-between">
        <div>
          <h3 class="text-2xl font-bold mb-4">Kundendienst &amp; Wartung</h3>
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="px-3 py-1 bg-surface-container text-xs font-semibold rounded-full uppercase">Heizungswartung</span>
            <span class="px-3 py-1 bg-surface-container text-xs font-semibold rounded-full uppercase">Sanitär</span>
            <span class="px-3 py-1 bg-surface-container text-xs font-semibold rounded-full uppercase">Kälte/Klima</span>
          </div>
          <p class="text-on-surface-variant leading-relaxed">Zuverlässige Wartung und schnelle Hilfe bei Störungen — für alle Ihre Haustechnik-Anlagen.</p>
        </div>
        <div class="mt-8 flex items-center justify-between">
          <Wrench class="w-10 h-10 text-outline-variant" />
          <a href="/leistungen/kundendienst/" class="text-primary font-bold">Details</a>
        </div>
      </div>

      <!-- Notdienst (full-width) -->
      <div class="col-span-12 bg-primary-container text-on-primary rounded-lg p-8 sm:p-12">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 md:gap-8">
          <div class="text-center md:text-left">
            <div class="w-14 h-14 bg-error rounded-full flex items-center justify-center animate-pulse shadow-[0_0_20px_rgba(186,26,26,0.6)] mx-auto md:mx-0 mb-4">
              <Headset class="w-7 h-7 text-white" />
            </div>
            <h3 class="text-2xl sm:text-3xl font-bold text-white mb-2">24/7 Notdienst</h3>
            <p class="text-white/70 text-sm sm:text-base">Rohrbruch, Heizungsausfall oder Stromstörung? Wir sind sofort für Sie da.</p>
          </div>
          <div class="text-center md:text-right shrink-0">
            <a href="tel:08935894978" class="inline-block text-xl sm:text-3xl font-black text-white mb-3 hover:text-secondary-container transition-colors whitespace-nowrap">
              089 / 35 89 49 78
            </a>
            <div>
              <a href="tel:08935894978" class="inline-flex items-center gap-2 text-secondary-container font-bold hover:underline transition-all text-sm">
                Sofort anrufen <ArrowRight class="w-4 h-4" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
