---
interface Step {
  number: string;
  title: string;
  description: string;
}

interface Props {
  title?: string;
  steps: Step[];
}

const { title = "So funktioniert's", steps } = Astro.props;
---

<section class="py-24 bg-surface-container-low">
  <div class="max-w-screen-2xl mx-auto px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-black tracking-tighter">{title}</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step) => (
        <div class="relative">
          <div class="text-6xl font-black text-secondary/15 mb-4">{step.number}</div>
          <h3 class="text-xl font-bold mb-2">{step.title}</h3>
          <p class="text-on-surface-variant leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
