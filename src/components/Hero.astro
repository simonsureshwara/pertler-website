---
---

<section class="relative pt-28 sm:pt-36 md:pt-48 pb-16 sm:pb-24 md:pb-32 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img
      src="/images/homepage-hero.webp"
      alt="Moderne Heizungsanlage in einem technischen Raum"
      class="w-full h-full object-cover"
      width="1920" height="1080"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <!-- Full overlay for readability on mobile, gradient on desktop -->
    <div class="absolute inset-0 bg-primary-container/75 md:bg-transparent"></div>
    <div class="absolute inset-0 hidden md:block bg-gradient-to-r from-primary-container/90 via-primary-container/50 to-transparent"></div>
  </div>

  <div class="relative z-10 max-w-screen-2xl mx-auto px-4 sm:px-8 w-full">
    <div class="max-w-3xl">
      <span class="inline-block px-4 py-1.5 bg-secondary-container text-on-secondary text-xs font-bold tracking-widest uppercase rounded-sm mb-4 sm:mb-6">
        Meisterbetrieb München · Seit 1984
      </span>
      <h1 class="font-black text-white leading-[1.1] mb-4 sm:mb-8 tracking-tighter" style="font-size: clamp(2rem, 6vw, 4.5rem);">
        Ihr Experte für Gebäudetechnik in München.
      </h1>
      <p class="text-base sm:text-xl md:text-2xl text-white font-light leading-relaxed mb-6 sm:mb-10 max-w-2xl">
        Heizung, Sanitär, Elektrotechnik, Bäder und Kältetechnik — alles aus einer Hand. Über 40 Jahre Erfahrung.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 sm:gap-5">
        <a
          href="/buchung/"
          class="w-full sm:w-auto px-8 sm:px-10 py-4 sm:py-5 bg-white text-on-surface rounded-md font-bold transition-all transform hover:-translate-y-1 editorial-shadow text-base sm:text-lg hover:bg-white/90 text-center"
        >
          Kostenlos beraten lassen
        </a>
        <a
          href="#leistungen"
          class="w-full sm:w-auto px-8 sm:px-10 py-4 sm:py-5 border-2 border-white/40 text-white hover:bg-white hover:text-primary rounded-md font-bold transition-all text-base sm:text-lg text-center"
        >
          Unsere Leistungen
        </a>
      </div>
    </div>
  </div>
</section>
