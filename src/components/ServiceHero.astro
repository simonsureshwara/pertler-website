---
import { Phone } from "lucide-astro";

interface Props {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  accent?: "heizung" | "elektro" | "baeder" | "sanitaer" | "error";
}

const colorMap: Record<string, { hex: string; gradientFrom: string }> = {
  heizung:  { hex: "#8b1a1a", gradientFrom: "from-[#8b1a1a]/90 via-[#8b1a1a]/40 to-transparent" },
  elektro:  { hex: "#00834b", gradientFrom: "from-[#00834b]/90 via-[#00834b]/40 to-transparent" },
  baeder:   { hex: "#e87d1e", gradientFrom: "from-[#e87d1e]/90 via-[#e87d1e]/40 to-transparent" },
  sanitaer: { hex: "#2e3b8c", gradientFrom: "from-[#2e3b8c]/90 via-[#2e3b8c]/40 to-transparent" },
  error:    { hex: "#ba1a1a", gradientFrom: "from-[#ba1a1a]/90 via-[#ba1a1a]/40 to-transparent" },
};

const { title, description, image, imageAlt, accent = "heizung" } = Astro.props;
const color = colorMap[accent];
---

<section class="relative min-h-[500px] flex items-center py-24 md:py-32 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img
      src={image}
      alt={imageAlt}
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class={`absolute inset-0 bg-gradient-to-r ${color.gradientFrom}`}></div>
  </div>

  <div class="relative z-10 max-w-screen-2xl mx-auto px-8 w-full">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-6xl font-black text-white leading-[1.1] mb-6 tracking-tighter">
        {title}
      </h1>
      <p class="text-lg md:text-xl text-white/90 font-light leading-relaxed mb-10 max-w-2xl">
        {description}
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href="/buchung/"
          class="px-8 py-4 text-white rounded-md font-bold transition-all text-base hover:opacity-90"
          style={`background-color: ${color.hex};`}
        >
          Kostenlose Beratung
        </a>
        <a
          href="tel:08935894978"
          class="px-8 py-4 border-2 border-white/40 text-white hover:bg-white hover:text-primary rounded-md font-bold transition-all flex items-center gap-3 text-base"
        >
          <Phone class="w-4 h-4" />
          089 / 35 89 49 78
        </a>
      </div>
    </div>
  </div>
</section>
