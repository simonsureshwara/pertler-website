---
import { Phone } from "lucide-astro";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Bereit für Ihr Projekt?", description = "Heizung, Bad, Elektro oder Notfall — wir sind für Sie da. Kostenloses Erstgespräch in 24h garantiert." } = Astro.props;
---

<section class="relative bg-primary-container overflow-hidden py-24 md:py-32">
  <div class="absolute inset-0 bg-gradient-to-br from-primary-container to-[#4A1218]"></div>
  <div class="relative z-10 max-w-screen-2xl mx-auto px-8 text-center">
    <h2 class="text-3xl md:text-5xl font-black text-white mb-6 tracking-tighter">{title}</h2>
    <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto mb-12">
      {description}
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
      <a href="/buchung/" class="w-full sm:w-auto px-10 py-5 bg-white text-primary rounded-md font-bold transition-all hover:scale-105 editorial-shadow text-lg">
        Angebot anfordern
      </a>
      <a href="tel:08935894978" class="w-full sm:w-auto px-10 py-5 border-2 border-white/40 text-white rounded-md font-bold transition-all hover:bg-white/10 flex items-center justify-center gap-3 text-lg">
        <Phone class="w-5 h-5" />
        089 / 35 89 49 78
      </a>
    </div>
  </div>
</section>
