---
import { ArrowRight } from "lucide-astro";

interface ServiceLink {
  title: string;
  description: string;
  href: string;
  borderColor: string;
}

interface Props {
  services: ServiceLink[];
  title?: string;
}

const { services, title = "Das könnte Sie auch interessieren" } = Astro.props;
---

<section class="py-24 bg-surface-container-low">
  <div class="max-w-screen-2xl mx-auto px-8">
    <h2 class="text-3xl font-black tracking-tighter mb-12">{title}</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {services.map((service) => (
        <a href={service.href} class={`group bg-surface-container-lowest p-8 rounded-xl editorial-shadow border-t-8 ${service.borderColor} hover:shadow-lg transition-all`}>
          <h3 class="text-xl font-bold mb-3 group-hover:text-secondary transition-colors">{service.title}</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed mb-6">{service.description}</p>
          <span class="text-primary font-bold flex items-center gap-2 group-hover:gap-4 transition-all text-sm">
            Mehr erfahren <ArrowRight class="w-4 h-4" />
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
