---
const serviceLinks = [
  { label: "Heizung & Sanitär", href: "/leistungen/heizung-sanitaer/" },
  { label: "Elektrotechnik", href: "/leistungen/elektrotechnik/" },
  { label: "Bäder & Wellness", href: "/leistungen/baeder-wellness/" },
  { label: "Kälte & Klima", href: "/leistungen/kaelte-klima/" },
  { label: "Kundendienst", href: "/leistungen/kundendienst/" },
  { label: "Notdienst", href: "/leistungen/notdienst/" },
];

const companyLinks = [
  { label: "Über uns", href: "/ueber-uns/" },
  { label: "Firmenhistorie", href: "/firmenhistorie/" },
  { label: "Auszeichnungen", href: "/auszeichnungen/" },
  { label: "Karriere", href: "/karriere/" },
  { label: "Kontakt", href: "/kontakt/" },
];

const legalLinks = [
  { label: "Impressum", href: "/impressum/" },
  { label: "Datenschutz", href: "/datenschutz/" },
  { label: "Widerrufsrecht", href: "/widerrufsrecht/" },
  { label: "Cookie-Einstellungen", href: "#" },
];
---

<footer class="bg-primary-container text-on-primary-container py-16 px-8">
  <div class="max-w-screen-2xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
    <!-- Brand -->
    <div class="space-y-6">
      <div class="text-2xl font-black text-white tracking-tight uppercase font-headline">PERTLER</div>
      <p class="text-white/60 text-sm leading-relaxed">
        Ihr inhabergeführter Meisterbetrieb in München. Heizung, Sanitär, Elektro, Bäder und Kältetechnik seit 1984.
      </p>
      <div class="space-y-2 text-sm text-white/60">
        <p>Wilhelmine-Reichard-Str. 24</p>
        <p>80935 München</p>
        <p class="font-bold text-white">089 / 35 89 49 78</p>
        <p>info@pertler.de</p>
      </div>
    </div>

    <!-- Leistungen -->
    <div>
      <h4 class="text-white font-bold mb-6 uppercase tracking-wider text-sm">Leistungen</h4>
      <ul class="space-y-4">
        {serviceLinks.map((link) => (
          <li>
            <a href={link.href} class="text-white/70 hover:text-white transition-all text-sm">{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Unternehmen -->
    <div>
      <h4 class="text-white font-bold mb-6 uppercase tracking-wider text-sm">Unternehmen</h4>
      <ul class="space-y-4">
        {companyLinks.map((link) => (
          <li>
            <a href={link.href} class="text-white/70 hover:text-white transition-all text-sm">{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Rechtliches -->
    <div>
      <h4 class="text-white font-bold mb-6 uppercase tracking-wider text-sm">Rechtliches</h4>
      <ul class="space-y-4">
        {legalLinks.map((link) => (
          <li>
            <a href={link.href} class="text-white/70 hover:text-white transition-all text-sm">{link.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="max-w-screen-2xl mx-auto mt-16 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4 text-white/40 text-xs">
    <p>© 2026 Ernst Pertler GmbH · Ernst Pertler Service GmbH · Pertler Bad GmbH · Pertler Elektrotechnik GmbH</p>
    <div class="flex gap-6">
      <a href="https://www.linkedin.com/company/ernst-pertler/" target="_blank" rel="noopener" class="hover:text-white transition-colors">LinkedIn</a>
      <a href="https://www.instagram.com/pertler_gebaeudetechnik/" target="_blank" rel="noopener" class="hover:text-white transition-colors">Instagram</a>
      <a href="https://www.facebook.com/Pertler.GmbH/" target="_blank" rel="noopener" class="hover:text-white transition-colors">Facebook</a>
    </div>
  </div>
</footer>
