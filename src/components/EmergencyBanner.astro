---
import { Phone, X } from "lucide-astro";
---

<div id="emergency-banner" class="bg-error text-on-error w-full py-2.5 px-4 relative z-[60]">
  <div class="max-w-screen-2xl mx-auto flex items-center justify-center gap-3 text-sm font-semibold">
    <Phone class="w-4 h-4 shrink-0" />
    <span>Notfall? Sofort anrufen:</span>
    <a href="tel:08935894978" class="underline underline-offset-2 hover:opacity-80 transition-opacity">
      089 / 35 89 49 78-10
    </a>
    <span class="hidden sm:inline">— 24h Notdienst</span>
    <button
      onclick="document.getElementById('emergency-banner').remove()"
      class="absolute right-4 top-1/2 -translate-y-1/2 p-1 hover:opacity-70 transition-opacity"
      aria-label="Banner schließen"
    >
      <X class="w-4 h-4" />
    </button>
  </div>
</div>
