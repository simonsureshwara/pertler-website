---
import BaseLayout from "../layouts/BaseLayout.astro";
import EmergencyBanner from "../components/EmergencyBanner.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ContactCTA from "../components/ContactCTA.astro";
import { Users, GraduationCap, Award, Lightbulb, Heart, Briefcase, ArrowRight, Building2 } from "lucide-astro";

const stats = [
  { value: "25+", label: "Mitarbeiter" },
  { value: "21", label: "Auszubildende" },
  { value: "4", label: "Fachbereiche" },
  { value: "2018", label: "Erasmus-Grasser-Preis" },
];

const reasons = [
  {
    icon: "shield",
    title: "Meisterbetrieb",
    description: "Arbeiten Sie in einem der renommiertesten Handwerksbetriebe Münchens — mit Meisterqualität in jedem Gewerk.",
  },
  {
    icon: "graduation",
    title: "Ausbildung mit Auszeichnung",
    description: "21 Azubis sprechen für sich. Unser Ausbildungskonzept wurde mit dem Erasmus-Grasser-Preis 2018 prämiert.",
  },
  {
    icon: "lightbulb",
    title: "Innovation (Top 100)",
    description: "Als Top 100 Innovator 2019 setzen wir auf digitale Prozesse, moderne Technik und zukunftssichere Lösungen.",
  },
  {
    icon: "heart",
    title: "Teamgeist",
    description: "Flache Hierarchien, familiäres Klima und echte Wertschätzung — bei uns ist jeder Mitarbeiter wichtig.",
  },
];

const jobs = [
  {
    title: "Anlagenmechaniker SHK (m/w/d)",
    department: "Heizung & Sanitär",
    type: "Vollzeit",
    description: "Montage, Wartung und Inbetriebnahme von Heizungs- und Sanitäranlagen in München und Umgebung.",
  },
  {
    title: "Elektriker / Elektroniker (m/w/d)",
    department: "Elektrotechnik",
    type: "Vollzeit",
    description: "Elektroinstallationen, Smart-Home-Systeme und E-Mobilität in Wohn- und Gewerbeobjekten.",
  },
  {
    title: "Kundendiensttechniker (m/w/d)",
    department: "Service",
    type: "Vollzeit",
    description: "Eigenverantwortlicher Kundendienst, Störungsbeseitigung und Wartung von Heizungs- und Sanitäranlagen.",
  },
  {
    title: "Ausbildungsplatz 2026 (m/w/d)",
    department: "Alle Fachbereiche",
    type: "Ausbildung",
    description: "Starte deine Karriere im Handwerk — in einem preisgekrönten Ausbildungsbetrieb mit echten Zukunftschancen.",
  },
];
---

<BaseLayout
  title="Karriere bei PERTLER | Jobs & Ausbildung in München"
  description="Karriere bei PERTLER Gebäudetechnik München. ✓ 21 Auszubildende ✓ Meisterbetrieb ✓ Offene Stellen in Heizung, Sanitär, Elektro & Bad"
>
  <EmergencyBanner />
  <Navbar />
  <main>

    <!-- ===== HERO ===== -->
    <section class="relative bg-primary-container overflow-hidden py-24 md:py-36">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-container to-[#4A1218]"></div>
      <div class="relative z-10 max-w-screen-2xl mx-auto px-8 text-center">
        <span class="text-secondary-container font-bold tracking-widest uppercase text-sm mb-6 block">Jobs & Ausbildung</span>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black text-white tracking-tighter leading-tight mb-6">
          Karriere bei PERTLER
        </h1>
        <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto">
          Gestalten Sie die Zukunft der Gebäudetechnik — in einem der innovativsten Meisterbetriebe Münchens.
        </p>
      </div>
    </section>

    <!-- ===== STATS BAR ===== -->
    <section class="bg-surface-container-lowest border-b border-outline-variant/15">
      <div class="max-w-screen-2xl mx-auto px-8 py-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          {stats.map((stat) => (
            <div>
              <div class="text-3xl md:text-4xl font-black text-primary mb-1">{stat.value}</div>
              <div class="text-sm font-bold uppercase tracking-widest text-on-surface-variant">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== WARUM PERTLER ===== -->
    <section class="py-24 md:py-32 bg-surface">
      <div class="max-w-screen-2xl mx-auto px-8">
        <div class="text-center mb-16">
          <span class="text-secondary font-bold tracking-widest uppercase text-sm mb-4 block">Ihre Vorteile</span>
          <h2 class="text-3xl md:text-5xl font-black tracking-tighter">Warum PERTLER?</h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {reasons.map((reason) => (
            <div class="bg-surface-container-lowest rounded-lg editorial-shadow p-8 text-center ghost-border">
              <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6">
                {reason.icon === "shield" && <Award class="w-8 h-8 text-primary" />}
                {reason.icon === "graduation" && <GraduationCap class="w-8 h-8 text-primary" />}
                {reason.icon === "lightbulb" && <Lightbulb class="w-8 h-8 text-primary" />}
                {reason.icon === "heart" && <Heart class="w-8 h-8 text-primary" />}
              </div>
              <h3 class="text-lg font-black mb-3">{reason.title}</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed">{reason.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== OFFENE STELLEN ===== -->
    <section class="py-24 md:py-32 bg-surface-container-low">
      <div class="max-w-screen-2xl mx-auto px-8">
        <div class="text-center mb-16">
          <span class="text-secondary font-bold tracking-widest uppercase text-sm mb-4 block">Jetzt bewerben</span>
          <h2 class="text-3xl md:text-5xl font-black tracking-tighter">Offene Stellen</h2>
        </div>

        <div class="max-w-3xl mx-auto space-y-6">
          {jobs.map((job) => (
            <div class="bg-surface-container-lowest rounded-lg editorial-shadow p-8 ghost-border flex flex-col md:flex-row md:items-center gap-6">
              <div class="flex-1">
                <div class="flex flex-wrap gap-2 mb-3">
                  <span class="px-3 py-1 bg-primary/10 text-primary text-xs font-bold rounded-full">{job.department}</span>
                  <span class:list={[
                    "px-3 py-1 text-xs font-bold rounded-full",
                    job.type === "Ausbildung"
                      ? "bg-secondary/10 text-secondary"
                      : "bg-surface-container-high text-on-surface-variant",
                  ]}>
                    {job.type}
                  </span>
                </div>
                <h3 class="text-xl font-black text-on-surface mb-2">{job.title}</h3>
                <p class="text-on-surface-variant text-sm leading-relaxed">{job.description}</p>
              </div>
              <a href="/kontakt/" class="flex items-center gap-2 text-primary font-bold text-sm hover:gap-3 transition-all whitespace-nowrap">
                Jetzt bewerben <ArrowRight class="w-4 h-4" />
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== AUSBILDUNG BEI PERTLER ===== -->
    <section class="py-24 md:py-32 bg-surface">
      <div class="max-w-screen-2xl mx-auto px-8">
        <div class="flex flex-col lg:flex-row gap-16 items-start">
          <!-- Text -->
          <div class="flex-1 space-y-8">
            <div>
              <span class="text-secondary font-bold tracking-widest uppercase text-sm mb-4 block">Nachwuchsförderung</span>
              <h2 class="text-3xl md:text-5xl font-black tracking-tighter leading-tight">Ausbildung bei PERTLER</h2>
            </div>
            <p class="text-lg text-on-surface-variant leading-relaxed">
              Mit 21 Auszubildenden gehören wir zu den engagiertesten Ausbildungsbetrieben im Münchner Handwerk. 2018 wurden wir dafür mit dem <strong class="text-on-surface">Erasmus-Grasser-Preis</strong> der Landeshauptstadt München ausgezeichnet — eine Anerkennung für vorbildliche Nachwuchsförderung.
            </p>
            <p class="text-lg text-on-surface-variant leading-relaxed">
              Unsere Azubis lernen von Anfang an am realen Projekt, werden von erfahrenen Meistern betreut und erhalten eine fundierte Ausbildung in allen Bereichen der Gebäudetechnik — von Heizung und Sanitär über Elektro bis hin zur Badsanierung.
            </p>
          </div>

          <!-- Was Azubis lernen -->
          <div class="flex-1 w-full lg:max-w-md">
            <div class="bg-surface-container-lowest rounded-lg editorial-shadow p-8 ghost-border">
              <h3 class="text-xl font-black mb-6">Was unsere Azubis lernen</h3>
              <ul class="space-y-4">
                <li class="flex items-start gap-3">
                  <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                    <Building2 class="w-4 h-4 text-primary" />
                  </div>
                  <div>
                    <div class="font-bold text-on-surface">Praxisnahe Ausbildung</div>
                    <div class="text-sm text-on-surface-variant">Reale Projekte von Tag eins an</div>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                    <Users class="w-4 h-4 text-primary" />
                  </div>
                  <div>
                    <div class="font-bold text-on-surface">Meister als Mentoren</div>
                    <div class="text-sm text-on-surface-variant">Persönliche Betreuung durch erfahrene Fachkräfte</div>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                    <Lightbulb class="w-4 h-4 text-primary" />
                  </div>
                  <div>
                    <div class="font-bold text-on-surface">Modernste Technik</div>
                    <div class="text-sm text-on-surface-variant">Digitale Tools und zukunftssichere Technologien</div>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                    <Briefcase class="w-4 h-4 text-primary" />
                  </div>
                  <div>
                    <div class="font-bold text-on-surface">Übernahmechancen</div>
                    <div class="text-sm text-on-surface-variant">Hohe Übernahmequote nach der Ausbildung</div>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CONTACT CTA ===== -->
    <ContactCTA title="Interesse geweckt?" description="Senden Sie uns Ihre Bewerbung oder rufen Sie uns an — wir freuen uns auf Sie!" />

  </main>
  <Footer />
</BaseLayout>
