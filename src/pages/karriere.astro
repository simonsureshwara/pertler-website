---
import BaseLayout from "../layouts/BaseLayout.astro";
import EmergencyBanner from "../components/EmergencyBanner.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ContactCTA from "../components/ContactCTA.astro";
import { Users, GraduationCap, Award, Lightbulb, Heart, Briefcase, ArrowRight, Building2, Mail, ChevronDown } from "lucide-astro";

const stats = [
  { value: "100", label: "Mitarbeiter" },
  { value: "21", label: "Auszubildende" },
  { value: "4", label: "Fachbereiche" },
  { value: "2018", label: "Erasmus-Grasser-Preis" },
];

const reasons = [
  {
    icon: "shield",
    title: "Meisterbetrieb",
    description: "Arbeiten Sie in einem der renommiertesten Handwerksbetriebe Münchens — mit Meisterqualität in jedem Gewerk.",
  },
  {
    icon: "graduation",
    title: "Ausbildung mit Auszeichnung",
    description: "21 Azubis sprechen für sich. Unser Ausbildungskonzept wurde mit dem Erasmus-Grasser-Preis 2018 prämiert.",
  },
  {
    icon: "lightbulb",
    title: "Innovation (Top 100)",
    description: "Als Top 100 Innovator 2019 setzen wir auf digitale Prozesse, moderne Technik und zukunftssichere Lösungen.",
  },
  {
    icon: "heart",
    title: "Teamgeist",
    description: "Flache Hierarchien, familiäres Klima und echte Wertschätzung — bei uns ist jeder Mitarbeiter wichtig.",
  },
];

const jobs = [
  {
    title: "Projektleiter/Meister – Heizung/Sanitär/Klima (m/w/d)",
    department: "Heizung & Sanitär",
    type: "Vollzeit",
    description: "Projektleitung für Heizungs- und Sanitärinstallationen in München und Umgebung.",
    tasks: [
      "Projektleitung für Heizungs- und Sanitärinstallationen",
      "Qualitäts-, Leistungs- und Terminüberwachung",
      "Geräte- und Materialdisposition",
      "Personaleinsatzplanung und Nachunternehmerkoordination",
      "Kunden- und Lieferantenverhandlungen",
      "Nachtragsmanagement und Arbeitssicherheit",
    ],
    requirements: [
      "Erfahrung in der Projektleitung im SHK-Bereich",
      "Hintergrund in Heizungs-, Sanitär- und Lüftungstechnik",
      "MS Office Kenntnisse",
      "Hands-on-Mentalität mit Unternehmergeist",
      "Verhandlungsgeschick und Organisationstalent",
      "Führerschein Klasse B",
    ],
    benefits: [
      "Attraktives Arbeitsumfeld in führendem Unternehmen",
      "Karrieremöglichkeiten und Weiterentwicklung",
      "Leistungsgerechte Vergütung",
      "Familiäre Unternehmenskultur mit Teamevents",
    ],
    email: "bewerbung@pertler.de",
  },
  {
    title: "Servicetechniker Heizung/Sanitär (m/w/d)",
    department: "Service",
    type: "Vollzeit",
    description: "Eigenverantwortlicher Kundendienst, Störungsbeseitigung und Wartung.",
    tasks: [
      "Service- und Reparaturarbeiten an Heizungs-, Sanitär- und Klimaanlagen",
      "Heizungswartungen durchführen",
      "Tabletbasierte Dokumentation im Außendienst",
      "Bereitschaftsdienst (alle 6 Wochen, mit Freizeitausgleich)",
      "Fehlerdiagnose und Störungsbeseitigung",
      "Protokolldokumentation",
    ],
    requirements: [
      "Abgeschlossene Ausbildung als Anlagenmechaniker SHK",
      "Berufserfahrung im Kundendienst",
      "Technisches Verständnis und Problemlösungskompetenz",
      "Freundliches Auftreten gegenüber Kunden",
      "Teamfähigkeit und Kommunikationsstärke",
      "Führerschein Klasse B",
    ],
    benefits: [
      "Firmenwagen mit kompletter Ausstattung",
      "Leistungsgerechte Bezahlung",
      "Fort- und Weiterbildungen",
      "Starkes Team und familiäre Atmosphäre",
    ],
    email: "bewerbung@pertler.de",
  },
  {
    title: "Fliesenleger/Naturstein (m/w/d)",
    department: "Bäder & Wellness",
    type: "Vollzeit",
    description: "Fliesen-, Platten- und Mosaikverlegung für anspruchsvolle Badprojekte.",
    tasks: [
      "Verlegen von Fliesen, Platten und Mosaik",
      "Untergrundvorbereitung und Estricharbeiten",
      "Reparatur- und Sanierungsprojekte",
      "Individuelle Kundeninstallationen",
      "Neubau- und Renovierungsarbeiten",
    ],
    requirements: [
      "Abgeschlossene Ausbildung als Fliesen-/Plattenleger",
      "Handwerkliches Geschick und Präzision",
      "Selbstständige und zuverlässige Arbeitsweise",
      "Kundenorientierung",
      "Führerschein Klasse B",
    ],
    benefits: [
      "Sicherer Arbeitsplatz in wachsendem Familienbetrieb",
      "Abwechslungsreiche Projekte (Privat & Gewerbe)",
      "Moderne Ausstattung und hochwertige Materialien",
      "Leistungsgerechte Vergütung",
    ],
    email: "bad@pertler.de",
  },
  {
    title: "Elektriker/Elektromonteur (m/w/d)",
    department: "Elektrotechnik",
    type: "Vollzeit",
    description: "Elektroinstallationen, Smart-Home-Systeme und Kundendienst.",
    tasks: [
      "Elektroinstallation in Neu- und Bestandsbauten",
      "Kundendienst: Reparaturen, Inbetriebnahmen, Wartungen",
      "Fehlerdiagnose an elektrischen Anlagen",
      "Montage und Demontage technischer Geräte",
    ],
    requirements: [
      "Abgeschlossene Ausbildung im Elektrohandwerk",
      "Baustellenerfahrung",
      "Verantwortungsbewusstsein und Sorgfalt",
      "Eigeninitiative und teamorientierte Arbeitsweise",
      "Deutschkenntnisse von Vorteil",
    ],
    benefits: [
      "Arbeitsplatz in führendem Unternehmen der Branche",
      "Karrierechancen in wachsender Abteilung",
      "Fort- und Weiterbildungsmöglichkeiten",
      "Leistungsgerechte Vergütung mit Prämien",
    ],
    email: "elektrotechnik@pertler.de",
  },
  {
    title: "Einkäufer/in – Heizung/Sanitär (m/w/d)",
    department: "Verwaltung",
    type: "Vollzeit",
    description: "Materialbeschaffung, Lieferantenmanagement und Preisverhandlungen.",
    tasks: [
      "Bedarfsermittlung und Anforderungsmanagement",
      "Selbstständige Lieferanten- und Konditionsverhandlungen",
      "Aufbau und Pflege des Lieferantennetzwerks",
      "Jahres- und Bonusverhandlungen mit Großhändlern",
      "Retourenmanagement und Lieferterminkontrolle",
      "Unterstützung bei Ausschreibungen",
    ],
    requirements: [
      "Kaufmännische oder technische Ausbildung (SHK bevorzugt)",
      "Mehrjährige Erfahrung in Materialwirtschaft oder Einkauf",
      "Angebotsanalyse und Verhandlungsgeschick",
      "MS Office (insb. Excel) und ERP-Systeme",
      "Sorgfältige, strukturierte Arbeitsweise",
      "Serviceorientierung und Kommunikationsstärke",
    ],
    benefits: [
      "Verantwortungsvolle Position mit Entwicklungspotenzial",
      "Leistungsgerechte Bezahlung mit Prämien",
      "Betriebliche Altersversorgung",
      "Weihnachts- und Urlaubsgeld",
    ],
    email: "bewerbung@pertler.de",
  },
  {
    title: "Ausbildungsplatz 2026 — Anlagenmechaniker SHK (m/w/d)",
    department: "Alle Fachbereiche",
    type: "Ausbildung",
    description: "Starte deine Karriere im preisgekrönten Ausbildungsbetrieb — 10 Bereiche, echte Projekte, Erasmus-Grasser-Preis.",
    tasks: [
      "Alle Bereiche der Gebäudetechnik kennenlernen",
      "Viermonatlicher Wechsel durch 10 Abteilungen",
      "Mitarbeit an realen Kundenprojekten",
      "Spezialisierung im 3. Lehrjahr",
    ],
    requirements: [
      "Mindestens Mittelschulabschluss",
      "Interesse an Technik und handwerkliches Geschick",
      "Teamfähigkeit und Zuverlässigkeit",
      "Motivation zum Lernen und Anpacken",
    ],
    benefits: [
      "Preisgekrönter Ausbildungsbetrieb (Erasmus-Grasser-Preis)",
      "10 Lehrlinge pro Jahrgang — intensive Betreuung",
      "Eigene Ausbilder: Heike Brandl & Lucas Zacher",
      "Hohe Übernahmequote nach der Ausbildung",
    ],
    email: "bewerbung@pertler.de",
  },
];
---

<BaseLayout
  title="Karriere bei PERTLER | Jobs & Ausbildung in München"
  description="Karriere bei PERTLER Gebäudetechnik München. ✓ 21 Auszubildende ✓ Meisterbetrieb ✓ Offene Stellen in Heizung, Sanitär, Elektro & Bad"
>
  <EmergencyBanner />
  <Navbar />
  <main id="main-content">

    <!-- ===== HERO ===== -->
    <section class="relative bg-primary-container overflow-hidden py-24 md:py-36">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-container to-[#4A1218]"></div>
      <div class="relative z-10 max-w-screen-2xl mx-auto px-8 text-center">
        <span class="text-secondary-container font-bold tracking-widest uppercase text-sm mb-6 block">Jobs & Ausbildung</span>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black text-white tracking-tighter leading-tight mb-6">
          Karriere bei PERTLER
        </h1>
        <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto">
          Gestalten Sie die Zukunft der Gebäudetechnik — in einem der innovativsten Meisterbetriebe Münchens.
        </p>
      </div>
    </section>

    <!-- ===== STATS BAR ===== -->
    <section class="bg-surface-container-lowest border-b border-outline-variant/15">
      <div class="max-w-screen-2xl mx-auto px-8 py-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          {stats.map((stat) => (
            <div>
              <div class="text-3xl md:text-4xl font-black text-primary mb-1">{stat.value}</div>
              <div class="text-sm font-bold uppercase tracking-widest text-on-surface-variant">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== WARUM PERTLER ===== -->
    <section class="py-24 md:py-32 bg-surface">
      <div class="max-w-screen-2xl mx-auto px-8">
        <div class="text-center mb-16">
          <span class="text-secondary font-bold tracking-widest uppercase text-sm mb-4 block">Ihre Vorteile</span>
          <h2 class="text-3xl md:text-5xl font-black tracking-tighter">Warum PERTLER?</h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {reasons.map((reason) => (
            <div class="bg-surface-container-lowest rounded-lg editorial-shadow p-8 text-center ghost-border">
              <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6">
                {reason.icon === "shield" && <Award class="w-8 h-8 text-primary" />}
                {reason.icon === "graduation" && <GraduationCap class="w-8 h-8 text-primary" />}
                {reason.icon === "lightbulb" && <Lightbulb class="w-8 h-8 text-primary" />}
                {reason.icon === "heart" && <Heart class="w-8 h-8 text-primary" />}
              </div>
              <h3 class="text-lg font-black mb-3">{reason.title}</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed">{reason.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== OFFENE STELLEN ===== -->
    <section class="py-24 md:py-32 bg-surface-container-low">
      <div class="max-w-screen-2xl mx-auto px-8">
        <div class="text-center mb-16">
          <span class="text-secondary font-bold tracking-widest uppercase text-sm mb-4 block">Jetzt bewerben</span>
          <h2 class="text-3xl md:text-5xl font-black tracking-tighter">Offene Stellen</h2>
        </div>

        <div class="max-w-4xl mx-auto space-y-4">
          {jobs.map((job, i) => (
            <div class="job-card bg-surface-container-lowest rounded-xl editorial-shadow ghost-border overflow-hidden" data-job={i}>
              <!-- Header (always visible, clickable) -->
              <button class="job-toggle w-full text-left p-6 sm:p-8 flex items-start sm:items-center justify-between gap-4 cursor-pointer hover:bg-surface-container-low/50 transition-colors" data-target={`job-detail-${i}`}>
                <div class="flex-1">
                  <div class="flex flex-wrap gap-2 mb-3">
                    <span class="px-3 py-1 bg-primary/10 text-primary text-xs font-bold rounded-full">{job.department}</span>
                    <span class:list={[
                      "px-3 py-1 text-xs font-bold rounded-full",
                      job.type === "Ausbildung"
                        ? "bg-secondary/10 text-secondary"
                        : "bg-surface-container-high text-on-surface-variant",
                    ]}>
                      {job.type}
                    </span>
                  </div>
                  <h3 class="text-lg sm:text-xl font-black text-on-surface mb-1">{job.title}</h3>
                  <p class="text-on-surface-variant text-sm">{job.description}</p>
                </div>
                <div class="job-chevron shrink-0 w-10 h-10 rounded-full bg-surface-container flex items-center justify-center transition-transform duration-300">
                  <ChevronDown class="w-5 h-5 text-on-surface-variant" />
                </div>
              </button>

              <!-- Details (expandable) -->
              <div id={`job-detail-${i}`} class="job-detail" style="max-height: 0; overflow: hidden; transition: max-height 0.4s ease;">
                <div class="px-6 sm:px-8 pb-8 pt-2">
                  <div class="border-t border-outline-variant/15 pt-6">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                      <!-- Aufgaben -->
                      <div>
                        <h4 class="text-sm font-black uppercase tracking-wider text-primary mb-4">Ihre Aufgaben</h4>
                        <ul class="space-y-2">
                          {job.tasks.map((task: string) => (
                            <li class="flex items-start gap-2 text-sm text-on-surface-variant">
                              <span class="text-secondary mt-1 shrink-0">•</span>
                              {task}
                            </li>
                          ))}
                        </ul>
                      </div>
                      <!-- Anforderungen -->
                      <div>
                        <h4 class="text-sm font-black uppercase tracking-wider text-primary mb-4">Was Sie mitbringen</h4>
                        <ul class="space-y-2">
                          {job.requirements.map((req: string) => (
                            <li class="flex items-start gap-2 text-sm text-on-surface-variant">
                              <span class="text-secondary mt-1 shrink-0">•</span>
                              {req}
                            </li>
                          ))}
                        </ul>
                      </div>
                      <!-- Benefits -->
                      <div>
                        <h4 class="text-sm font-black uppercase tracking-wider text-primary mb-4">Was wir bieten</h4>
                        <ul class="space-y-2">
                          {job.benefits.map((benefit: string) => (
                            <li class="flex items-start gap-2 text-sm text-on-surface-variant">
                              <span class="text-secondary mt-1 shrink-0">✓</span>
                              {benefit}
                            </li>
                          ))}
                        </ul>
                      </div>
                    </div>
                    <!-- CTA -->
                    <div class="mt-8 flex flex-col sm:flex-row items-start sm:items-center gap-4">
                      <a href={`mailto:${job.email}`} class="inline-flex items-center gap-3 px-6 py-3 bg-secondary text-white rounded-md font-bold transition-all hover:bg-secondary-container text-sm">
                        <Mail class="w-4 h-4" />
                        Jetzt bewerben
                      </a>
                      <span class="text-xs text-on-surface-variant">Bewerbung an: {job.email}</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== AZUBI GRUPPENFOTO ===== -->
    <section class="relative h-[300px] sm:h-[400px] md:h-[500px] overflow-hidden">
      <img
        src="/images/azubi-gruppe.webp"
        alt="Pertler Auszubildende — Gruppenfoto"
        class="w-full h-full object-cover object-[center_15%]"
        width="1600" height="600"
        loading="lazy"
        decoding="async"
      />
    </section>

    <!-- ===== AUSBILDUNG BEI PERTLER ===== -->
    <section class="py-24 md:py-32 bg-surface">
      <div class="max-w-screen-2xl mx-auto px-4 sm:px-8">
        <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-start">
          <!-- Text -->
          <div class="flex-1 space-y-8">
            <div>
              <span class="text-secondary font-bold tracking-widest uppercase text-sm mb-4 block">Nachwuchsförderung</span>
              <h2 class="text-2xl sm:text-3xl md:text-5xl font-black tracking-tighter leading-tight">Wir schreiben Ausbildung GROSS!</h2>
            </div>

            <!-- Zitat Stefan Pertler -->
            <div class="bg-surface-container-low p-6 sm:p-8 rounded-xl">
              <p class="text-on-surface-variant leading-relaxed mb-4">
                „Ich bin gemeinsam mit unseren beiden Ausbildern, Heike Brandl und Lucas Zacher, für die Ausbildung unseres Nachwuchses verantwortlich. Uns ist wichtig, dass unsere Lehrlinge <strong class="text-on-surface">alle Seiten des Berufes</strong> kennenlernen. Mit der Größe und der Vielseitigkeit in unserem Betrieb ist es möglich, dies zu bieten."
              </p>
              <div class="flex items-center gap-3">
                <img src="/images/team/leitung/geschaeftsfuehrung.webp" alt="Stefan Pertler" width="48" height="48" class="w-12 h-12 rounded-full object-cover" loading="lazy" decoding="async" />
                <div>
                  <div class="font-bold text-sm">Stefan Pertler</div>
                  <div class="text-xs text-on-surface-variant">Geschäftsführer & Ausbildungsverantwortlicher</div>
                </div>
              </div>
            </div>

            <p class="text-on-surface-variant leading-relaxed">
              In jedem Jahrgang bilden wir ca. <strong class="text-on-surface">10 Lehrlinge</strong> aus, die von uns intensiv betreut werden. 2018 wurden wir dafür mit dem <strong class="text-on-surface">Erasmus-Grasser-Preis</strong> der Landeshauptstadt München ausgezeichnet.
            </p>

            <!-- Azubi-Zitat -->
            <div class="bg-secondary/5 p-6 rounded-xl border-l-4 border-secondary">
              <p class="text-on-surface-variant italic leading-relaxed mb-2">„Toll finde ich, alle Bereiche unseres Berufes kennenzulernen und im Team zu sein. Wir dürfen mitmachen und anpacken, anstatt nur zuzuschauen!"</p>
              <div class="text-xs font-bold text-secondary">— Auszubildender bei PERTLER</div>
            </div>

            <!-- CTA -->
            <div class="pt-4">
              <p class="text-on-surface font-bold mb-4">Lust auf eine Ausbildung als Anlagenmechaniker?</p>
              <a href="mailto:bewerbung@pertler.de" class="inline-flex items-center gap-3 px-8 py-4 bg-secondary text-white rounded-md font-bold transition-all hover:bg-secondary-container text-base">
                <Mail class="w-5 h-5" />
                bewerbung@pertler.de
              </a>
            </div>
          </div>

          <!-- Ausbildungsplan -->
          <div class="flex-1 w-full lg:max-w-md space-y-6">
            <div class="bg-surface-container-lowest rounded-lg editorial-shadow p-6 sm:p-8 ghost-border">
              <h3 class="text-xl font-black mb-2">Ausbildungsplan</h3>
              <p class="text-sm text-on-surface-variant mb-6">Viermonatlicher Wechsel durch alle Bereiche:</p>
              <ol class="space-y-3">
                {[
                  "Neubauinstallation Heizung/Sanitär",
                  "Sanierung bestehender Gebäude",
                  "Badumbau und Fertigbad",
                  "Wohnungssanierung & Dachgeschossausbau",
                  "Heizkessel und Heizungsanlagen",
                  "Trinkwasserhygiene & Gefährdungsanalysen",
                  "Kundendienst/Wartung Heizung",
                  "Kundendienst Sanitär",
                  "Leckortung & regenerative Techniken",
                  "Elektrotechnik",
                ].map((item, i) => (
                  <li class="flex items-start gap-3">
                    <span class="w-6 h-6 bg-primary/10 rounded-full flex items-center justify-center shrink-0 text-xs font-black text-primary mt-0.5">{i + 1}</span>
                    <span class="text-sm text-on-surface-variant">{item}</span>
                  </li>
                ))}
              </ol>
            </div>

            <div class="bg-surface-container-lowest rounded-lg editorial-shadow p-6 sm:p-8 ghost-border">
              <h3 class="text-lg font-black mb-4">Im 3. Lehrjahr: Spezialisierung</h3>
              <p class="text-sm text-on-surface-variant leading-relaxed">
                Aus den Beurteilungen der Gesellen, den Wünschen des Azubis und den individuellen Begabungen wird gemeinsam ein Fachgebiet ausgewählt. Im letzten Ausbildungsjahr wird auf selbstständiges Arbeiten Wert gelegt — so dass der angehende Monteur mit breiter Brust die Prüfung antreten kann.
              </p>
            </div>

            <div class="bg-surface-container-lowest rounded-lg editorial-shadow p-6 sm:p-8 ghost-border">
              <h3 class="text-lg font-black mb-4">Gegenseitige Bewertung</h3>
              <p class="text-sm text-on-surface-variant leading-relaxed">
                Nach jedem Quartal bewerten sich Azubi und Obermonteur gegenseitig. Diese Bögen bleiben vertraulich, dienen aber der Verbesserung und Motivation aller Beteiligten.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CONTACT CTA ===== -->

  </main>
  <Footer />

  <script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var toggles = document.querySelectorAll('.job-toggle');

    toggles.forEach(function(toggle) {
      toggle.addEventListener('click', function() {
        var targetId = toggle.getAttribute('data-target');
        var detail = document.getElementById(targetId);
        var chevron = toggle.querySelector('.job-chevron');
        var isOpen = detail.style.maxHeight !== '0px' && detail.style.maxHeight !== '';

        // Close all others
        document.querySelectorAll('.job-detail').forEach(function(d) {
          d.style.maxHeight = '0px';
        });
        document.querySelectorAll('.job-chevron').forEach(function(c) {
          c.style.transform = '';
        });

        // Toggle clicked
        if (!isOpen) {
          detail.style.maxHeight = detail.scrollHeight + 'px';
          chevron.style.transform = 'rotate(180deg)';
        }
      });
    });
  });
  </script>
</BaseLayout>
