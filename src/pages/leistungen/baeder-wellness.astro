---
import ServiceLayout from "../../layouts/ServiceLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import ServiceHero from "../../components/ServiceHero.astro";
import TrustStats from "../../components/TrustStats.astro";
import FeatureGrid from "../../components/FeatureGrid.astro";
import ProcessSteps from "../../components/ProcessSteps.astro";
import FAQSection from "../../components/FAQSection.astro";
import ContactCTA from "../../components/ContactCTA.astro";
import RelatedServices from "../../components/RelatedServices.astro";
import { Star } from "lucide-astro";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Badsanierung München",
  "description": "Komplettbadsanierung in München vom Meisterbetrieb. Festpreisangebote, eigene Fliesenleger, barrierefreie Bäder — Planung bis Fertigstellung.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Ernst Pertler GmbH",
    "url": "https://www.pertler.de"
  },
  "areaServed": { "@type": "City", "name": "München" }
};

const stats = [
  { icon: "✓", text: "Festpreisangebote" },
  { icon: "🏆", text: "Bayerns Best 50" },
  { icon: "👷", text: "Eigene Fliesenleger" },
  { icon: "📐", text: "Komplettplanung" },
];

const features = [
  { icon: "🛁", title: "Komplette Badsanierung", description: "Vom Rückbau bis zur Fertigstellung — alle Gewerke aus einer Hand, termingerecht und sauber." },
  { icon: "🖥️", title: "Badplanung & 3D-Gestaltung", description: "Ihr Traumbad vorab erleben: fotorealistische 3D-Planung für perfekte Entscheidungen." },
  { icon: "🪨", title: "Fliesenarbeiten & Naturstein", description: "Eigene Fliesenleger für höchste Qualität bei Fliesen, Mosaik und Natursteinbelägen." },
  { icon: "♿", title: "Barrierefreier Umbau", description: "Bodengleiche Duschen, Haltegriffe und schwellenlose Zugänge — förderfähig und komfortabel." },
  { icon: "🧱", title: "Trockenbau & Vorwandinstallation", description: "Saubere Vorwandkonstruktionen für verdeckte Leitungsführung und moderne Optik." },
  { icon: "⚡", title: "Elektroarbeiten im Bad", description: "Normgerechte Elektroinstallation inkl. Spiegelbeleuchtung und Fußbodenheizung." },
  { icon: "📏", title: "Kleine-Bäder-Lösungen", description: "Clevere Raumkonzepte für kleine Bäder — jeder Zentimeter optimal genutzt." },
  { icon: "🧖", title: "Wellness & Spa-Ausstattung", description: "Dampfdusche, Regenbrause oder Whirlpool — wir machen Ihr Bad zur Wohlfühloase." },
];

const steps = [
  { number: "01", title: "Traumgespräch", description: "Wir besprechen Ihre Wünsche, Vorstellungen und Rahmenbedingungen persönlich vor Ort." },
  { number: "02", title: "Planung", description: "3D-Entwurf Ihres neuen Bades mit detailliertem Festpreisangebot — ohne versteckte Kosten." },
  { number: "03", title: "Sanierung", description: "Alle Gewerke koordiniert aus einer Hand: Sanitär, Fliesen, Elektro und Trockenbau." },
  { number: "04", title: "Übergabe", description: "Ihr neues Traumbad — termingerecht, sauber und mit persönlicher Einweisung übergeben." },
];

const faqs = [
  {
    question: "Was kostet eine Badsanierung in München?",
    answer: "Je nach Größe und Ausstattung liegt eine Komplettsanierung zwischen 8.000 und 25.000 Euro. Sie erhalten von uns immer ein verbindliches Festpreisangebot — ohne versteckte Kosten oder Nachforderungen.",
  },
  {
    question: "Wie lange dauert eine Badsanierung?",
    answer: "Eine Standard-Badsanierung dauert 2-4 Wochen je nach Umfang. Sie erhalten vorab einen verbindlichen Zeitplan, damit Sie sich darauf einstellen können.",
  },
  {
    question: "Gibt es Förderung für barrierefreie Bäder?",
    answer: "Ja, die KfW fördert barrierefreie Badumbauten mit bis zu 6.250 Euro Zuschuss. Zusätzlich können Pflegebedürftige bei der Pflegekasse bis zu 4.000 Euro beantragen. Wir beraten Sie zu allen Fördermöglichkeiten.",
  },
  {
    question: "Bekomme ich ein Festpreisangebot?",
    answer: "Ja, immer. Jedes Angebot von uns ist ein verbindlicher Festpreis. Sie wissen vorab exakt, was Ihr neues Bad kostet — ohne versteckte Kosten oder böse Überraschungen.",
  },
  {
    question: "Kann ich mein Bad während der Sanierung nutzen?",
    answer: "Nein, während der Sanierung ist das Bad nicht nutzbar. Wir besprechen vorab Übergangslösungen mit Ihnen und sorgen dafür, dass die Bauzeit so kurz wie möglich bleibt.",
  },
];

const relatedServices = [
  { title: "Heizung & Sanitär", description: "Heizungsanlagen und Sanitärinstallationen vom Meisterbetrieb.", href: "/leistungen/heizung-sanitaer/", borderColor: "border-primary" },
  { title: "Elektrotechnik", description: "Elektroinstallationen und Smart Home für Ihr Zuhause.", href: "/leistungen/elektrotechnik/", borderColor: "border-elektro" },
  { title: "Kundendienst & Wartung", description: "Regelmäßige Wartung und schnelle Hilfe bei Störungen.", href: "/leistungen/kundendienst/", borderColor: "border-sanitaer" },
];
---

<ServiceLayout
  title="Badsanierung & Wellness in München — Komplett aus einer Hand | PERTLER"
  description="Komplettbadsanierung in München vom Meisterbetrieb. ✓ Festpreisangebote ✓ Eigene Fliesenleger ✓ Barrierefreie Bäder ✓ Planung bis Fertigstellung"
  serviceSchema={serviceSchema}
>
  <Breadcrumb items={[
    { label: "Startseite", href: "/" },
    { label: "Leistungen", href: "/leistungen/" },
    { label: "Bäder & Wellness" },
  ]} />

  <ServiceHero
    title="Badsanierung & Wellness in München — Komplett aus einer Hand"
    description="Vom Traumgespräch bis zur Übergabe — Ihr Meisterbetrieb für Komplettsanierungen seit 1984. Eigene Fliesenleger, koordinierte Gewerke, Festpreisgarantie."
    image="https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?w=1920&q=80"
    imageAlt="Modernes Badezimmer nach Komplettsanierung in München"
    accent="baeder"
  />

  <TrustStats stats={stats} accent="baeder" />

  <!-- Über diese Abteilung -->
  <section class="py-24 bg-surface">
    <div class="max-w-screen-2xl mx-auto px-8">
      <div class="flex flex-col lg:flex-row gap-16 items-start">
        <div class="flex-1 space-y-6">
          <span class="font-bold tracking-widest uppercase text-sm block" style="color: #e87d1e;">Pertler Bad GmbH</span>
          <h2 class="text-3xl md:text-4xl font-black tracking-tighter">Ihr Bad — so individuell wie Sie.</h2>
          <p class="text-on-surface-variant text-lg leading-relaxed">
            „Ein Badezimmer ist höchst individuell, eine persönliche Visitenkarte" — nach diesem Prinzip arbeitet unsere Bad-Abteilung. Von der funktionalen Standardsanierung bis zur luxuriösen Wellness-Oase koordinieren wir alle Gewerke unter einem Dach: Sanitär, Fliesen, Trockenbau, Elektro, Maurer- und Putzarbeiten.
          </p>
          <p class="text-on-surface-variant leading-relaxed">
            Das Ergebnis: Ein Festpreisangebot, ein Ansprechpartner und ein perfektes Bad — termingerecht und ohne böse Überraschungen. Unsere eigenen Fliesenleger und die enge Koordination mit allen Handwerkern garantieren eine Installationsqualität, die genauso wichtig ist wie die Optik. Denn nur ein fachgerecht installiertes Bad hält Jahrzehnte.
          </p>
          <div class="flex flex-wrap gap-4 pt-4">
            <span class="px-4 py-2 bg-surface-container rounded-full text-sm font-semibold">Festpreisgarantie</span>
            <span class="px-4 py-2 bg-surface-container rounded-full text-sm font-semibold">Eigene Fliesenleger</span>
            <span class="px-4 py-2 bg-surface-container rounded-full text-sm font-semibold">Alle Gewerke koordiniert</span>
          </div>
        </div>
        <div class="lg:w-80 shrink-0 bg-surface-container-lowest p-8 rounded-xl editorial-shadow space-y-6">
          <div>
            <div class="text-4xl font-black" style="color: #e87d1e;">✓</div>
            <div class="text-sm font-semibold text-on-surface-variant">Festpreisangebot garantiert</div>
          </div>
          <div class="border-t border-outline-variant/15 pt-6">
            <div class="text-4xl font-black" style="color: #e87d1e;">1</div>
            <div class="text-sm font-semibold text-on-surface-variant">Ansprechpartner für alles</div>
          </div>
          <div class="border-t border-outline-variant/15 pt-6">
            <div class="text-4xl font-black" style="color: #e87d1e;">5+</div>
            <div class="text-sm font-semibold text-on-surface-variant">Gewerke aus einer Hand</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FeatureGrid
    title="Unsere Leistungen im Überblick"
    subtitle="Bäder & Wellness"
    features={features}
    accent="baeder"
  />

  <ProcessSteps steps={steps} />

  <FAQSection faqs={faqs} accent="baeder" />

  <!-- Testimonial Section -->
  <section class="py-24 bg-surface-container-low">
    <div class="max-w-screen-2xl mx-auto px-8">
      <div class="text-center mb-16">
        <span class="text-secondary font-bold tracking-widest uppercase text-sm mb-4 block">Kundenstimmen</span>
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter">Was unsere Kunden sagen.</h2>
      </div>
      <div class="max-w-2xl mx-auto">
        <div class="bg-surface-container-lowest p-10 rounded-xl editorial-shadow">
          <div class="flex gap-1 mb-6">
            {Array.from({ length: 5 }).map(() => (
              <Star class="w-5 h-5 text-secondary fill-secondary" />
            ))}
          </div>
          <p class="text-on-surface-variant leading-relaxed mb-8 italic">"Unser neues Badezimmer ist ein Traum. Das Pertler-Team hat unsere Vorstellungen perfekt umgesetzt und war dabei stets sauber und pünktlich."</p>
          <div class="border-t border-outline-variant/15 pt-6">
            <div class="font-bold text-on-surface">Dr. Martin Weber</div>
            <div class="text-sm text-on-surface-variant">München-Feldmoching · Badsanierung</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ContactCTA accent="baeder" />

  <RelatedServices services={relatedServices} />
</ServiceLayout>
