---
import ServiceLayout from "../../layouts/ServiceLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import ServiceHero from "../../components/ServiceHero.astro";
import TrustStats from "../../components/TrustStats.astro";
import FeatureGrid from "../../components/FeatureGrid.astro";
import ProcessSteps from "../../components/ProcessSteps.astro";
import FAQSection from "../../components/FAQSection.astro";
import ContactCTA from "../../components/ContactCTA.astro";
import RelatedServices from "../../components/RelatedServices.astro";
import Testimonials from "../../components/Testimonials.astro";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Elektrotechnik & Smart Home",
  "description": "Elektroinstallationen und Smart Home vom Meisterbetrieb in München. Homematic IP Partner, E-Ladestationen, Neubau und Sanierung.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Ernst Pertler GmbH",
    "url": "https://www.pertler.de"
  },
  "areaServed": { "@type": "City", "name": "München" }
};

const stats = [
  { icon: "✓", text: "Homematic IP Partner" },
  { icon: "car", text: "Ferrari Showroom Referenz" },
  { icon: "zap", text: "Meisterbetrieb" },
  { icon: "house", text: "Komplettservice" },
];

const features = [
  { icon: "construction", title: "Elektroinstallation Neubau", description: "Komplette Elektroplanung und -installation für Neubauprojekte." },
  { icon: "refresh", title: "Elektrosanierung Bestand", description: "Modernisierung der Elektrik in Bestandsgebäuden und Altbauten." },
  { icon: "home", title: "Smart Home", description: "Homematic IP Partner — intelligente Steuerung für Licht, Heizung und Sicherheit." },
  { icon: "lightbulb", title: "Lichtkonzepte", description: "Moderne Beleuchtungsplanung für Wohn- und Gewerberäume." },
  { icon: "bell", title: "Sprechanlagen", description: "Türkommunikation und Gegensprechanlagen für Mehrfamilienhäuser." },
  { icon: "plug", title: "E-Mobilität", description: "Installation von Wallboxen und Ladestationen für Elektrofahrzeuge." },
  { icon: "flame", title: "Heizungsanschlüsse", description: "Elektrische Anschlüsse für Heizungsanlagen und Wärmepumpen." },
  { icon: "zap", title: "Schnellreparatur", description: "Elektrische Störungen schnell und zuverlässig beseitigt." },
];

const steps = [
  { number: "01", title: "Beratung", description: "Kostenlose Erstberatung und Bestandsaufnahme Ihrer elektrischen Anlage." },
  { number: "02", title: "Konzept", description: "Individuelle Planung mit Smart-Home-Integration und Energieeffizienz." },
  { number: "03", title: "Installation", description: "Fachgerechte Ausführung durch unsere Elektromeister. Sauber und termingerecht." },
  { number: "04", title: "Einweisung", description: "Übergabe mit persönlicher Einweisung in Ihre neue Elektroanlage." },
];

const faqs = [
  {
    question: "Was kostet eine Elektroinstallation im Neubau?",
    answer: "Die Elektroinstallation macht typischerweise 3-5% der Gesamtbaukosten aus. Für ein Einfamilienhaus rechnen Sie mit 15.000-30.000 Euro je nach Ausstattungsniveau und Smart-Home-Integration.",
  },
  {
    question: "Lohnt sich Smart Home im Altbau?",
    answer: "Ja, moderne Funkbasierte Systeme wie Homematic IP lassen sich ohne aufwendige Verkabelung nachrüsten. Die Investition amortisiert sich durch Energieeinsparungen und erhöhten Wohnkomfort.",
  },
  {
    question: "Wie installiere ich eine E-Ladestation zuhause?",
    answer: "Wir prüfen Ihren Hausanschluss, beraten zur passenden Wallbox und übernehmen die komplette Installation inkl. Anmeldung beim Netzbetreiber. In der Regel ist die Installation in einem Tag erledigt.",
  },
  {
    question: "Bieten Sie Elektro-Notdienst an?",
    answer: "Ja, über unseren 24h-Notdienst unter 089 / 35 89 49 78 sind wir auch bei elektrischen Störungen rund um die Uhr erreichbar.",
  },
  {
    question: "Welches Smart Home System empfehlen Sie?",
    answer: "Als zertifizierter Homematic IP Partner empfehlen wir dieses System für seine Zuverlässigkeit, Datensicherheit (lokale Verarbeitung) und einfache Erweiterbarkeit.",
  },
];

const relatedServices = [
  { title: "Heizung & Sanitär", description: "Heizungsanlagen und Sanitärinstallationen.", href: "/leistungen/heizung-sanitaer/", borderColor: "border-primary" },
  { title: "Kundendienst & Wartung", description: "Wartung und Service für alle Ihre Anlagen.", href: "/leistungen/kundendienst/", borderColor: "border-sanitaer" },
  { title: "Bäder & Wellness", description: "Komplette Badsanierung inkl. Elektroarbeiten.", href: "/leistungen/baeder-wellness/", borderColor: "border-baeder" },
];
---

<ServiceLayout
  title="Elektrotechnik & Smart Home in München — Installation & Service | PERTLER"
  description="Elektroinstallationen & Smart Home vom Meisterbetrieb in München. ✓ Homematic IP Partner ✓ E-Ladestationen ✓ Neubau & Sanierung"
  serviceSchema={serviceSchema}
  preloadImage="/images/elektro-hero.webp" activeCompany="elektro"
>
  <Breadcrumb items={[
    { label: "Startseite", href: "/" },
    { label: "Leistungen", href: "/leistungen/" },
    { label: "Elektrotechnik & Smart Home" },
  ]} />

  <ServiceHero
    title="Elektrotechnik & Smart Home in München — Installation & Service"
    description="Von der Elektroinstallation bis zum Smart Home — Ihr Elektromeisterbetrieb seit 1984. Neubau, Sanierung und intelligente Gebäudetechnik."
    image="/images/elektro-hero.webp"
    imageAlt="Elektrotechnik und Smart Home Installation in München"
    accent="elektro"
  />

  <TrustStats stats={stats} accent="elektro" />

  <!-- Über diese Abteilung -->
  <section class="py-24 bg-surface">
    <div class="max-w-screen-2xl mx-auto px-8">
      <div class="flex flex-col lg:flex-row gap-16 items-start">
        <div class="flex-1 space-y-6">
          <span class="font-bold tracking-widest uppercase text-sm block" style="color: #00834b;">Pertler Elektrotechnik GmbH</span>
          <h2 class="text-3xl md:text-4xl font-black tracking-tighter">Elektro-Kompetenz vom Meisterbetrieb.</h2>
          <p class="text-on-surface-variant text-lg leading-relaxed">
            Unsere Elektrotechnik-Abteilung liefert komplette Elektroinstallationen für Neubauten, Sanierungen und Umbauten — kombiniert mit intelligenten Smart-Home-Lösungen für mehr Komfort und Energieeffizienz. Als zertifizierter Homematic IP Partner bieten wir zukunftssichere Gebäudeautomation.
          </p>
          <p class="text-on-surface-variant leading-relaxed">
            Von modernen Lichtkonzepten über Sprechanlagen und E-Mobilität-Ladestationen bis hin zu komplexen Heizungsanschlüssen — wir verbinden handwerkliche Präzision mit modernster Technologie. Referenzprojekte wie der Ferrari Showroom am Odeonsplatz und das Next 123 am Maximiliansplatz zeigen unsere Leistungsfähigkeit auch bei anspruchsvollen Gewerbeprojekten.
          </p>
          <div class="flex flex-wrap gap-4 pt-4">
            <span class="px-4 py-2 bg-surface-container rounded-full text-sm font-semibold">Homematic IP Partner</span>
            <span class="px-4 py-2 bg-surface-container rounded-full text-sm font-semibold">E-Mobilität</span>
            <span class="px-4 py-2 bg-surface-container rounded-full text-sm font-semibold">Smart Home</span>
          </div>
        </div>
        <div class="w-full lg:w-80 shrink-0 bg-surface-container-lowest p-8 rounded-xl editorial-shadow space-y-6">
          <div class="text-xs font-bold uppercase tracking-widest text-on-surface-variant/60 mb-4">Referenzen & Partner</div>
          <div>
            <div class="text-2xl font-black" style="color: #00834b;">Ferrari Showroom</div>
            <div class="text-sm font-semibold text-on-surface-variant">Odeonsplatz München</div>
          </div>
          <div class="border-t border-outline-variant/15 pt-6">
            <div class="text-2xl font-black" style="color: #00834b;">Next 123</div>
            <div class="text-sm font-semibold text-on-surface-variant">Maximiliansplatz München</div>
          </div>
          <div class="border-t border-outline-variant/15 pt-6">
            <div class="text-2xl font-black" style="color: #00834b;">Homematic IP</div>
            <div class="text-sm font-semibold text-on-surface-variant">Zertifizierter Partner</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FeatureGrid
    title="Unsere Elektro-Leistungen"
    subtitle="Elektrotechnik & Smart Home"
    features={features}
    accent="elektro"
  />

  <ProcessSteps steps={steps} />

  <FAQSection faqs={faqs} accent="elektro" />

  <Testimonials filter="elektro" />

  <ContactCTA accent="elektro" />

  <RelatedServices services={relatedServices} />
</ServiceLayout>
